# AI Timetable Scheduler - Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=timetable
DB_NAME=Time-Table-Scheduler

# ============================================
# Security Configuration
# ============================================
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# CORS & Origin Configuration
# ============================================
# Add all domains where frontend will be hosted
# Format: http://localhost:3002,http://yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3002

# ============================================
# Solver Configuration
# ============================================
# Time limit for timetable generation (in seconds)
SOLVER_TIME_LIMIT_SECONDS=300

# ============================================
# Optional: AI Integration
# ============================================
# For future AI features (Gemini API key)
GEMINI_API_KEY=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@yourdomain.com
